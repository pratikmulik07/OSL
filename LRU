#include <stdio.h>

int main() {
    int pages[50], frames[10], time[10];
    int n, f, i, j, k;
    int page_faults = 0, counter = 0, flag;

    printf("Enter number of pages: ");
    scanf("%d", &n);

    printf("Enter reference string: ");
    for(i = 0; i < n; i++) scanf("%d", &pages[i]);

    printf("Enter number of frames (>=3): ");
    scanf("%d", &f);

    for(i = 0; i < f; i++) frames[i] = -1;

    printf("\nPage\tFrames\t\tStatus\n");

    for(i = 0; i < n; i++) {
        flag = 0;

        for(j = 0; j < f; j++) {
            if(frames[j] == pages[i]) {
                counter++;
                time[j] = counter;
                flag = 1;
                break;
            }
        }

        if(flag == 0) {
            int min = 9999, pos = 0;

            for(j = 0; j < f; j++) {
                if(frames[j] == -1) {
                    pos = j;
                    break;
                }
                if(time[j] < min) {
                    min = time[j];
                    pos = j;
                }
            }

            frames[pos] = pages[i];
            counter++;
            time[pos] = counter;
            page_faults++;

            printf("%d\t", pages[i]);
            for(k = 0; k < f; k++)
                printf("%d ", frames[k]);
            printf("\tFault\n");
        } else {
            printf("%d\t", pages[i]);
            for(k = 0; k < f; k++)
                printf("%d ", frames[k]);
            printf("\tHit\n");
        }
    }

    printf("\nTotal Page Faults = %d\n", page_faults);
    printf("Total Page Hits = %d\n", n - page_faults);

    return 0;
}
