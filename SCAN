#include<stdio.h>
#include<stdlib.h>

void sort(int arr[], int n){
    for(int i=0;i<n-1;i++){
        for(int j=0;j<n-i-1;j++){
            if(arr[j] > arr[j+1]){
                int temp = arr[j];
                arr[j] = arr[j+1];
                arr[j+1] = temp;
            }
        }
    }
}

int main(){
    int req[100], n, head, size, dir, index = 0;
    int total = 0;

    printf("Enter total number of requests: ");
    scanf("%d", &n);

    printf("Enter request queue: ");
    for(int i=0;i<n;i++){
        scanf("%d", &req[i]);
    }

    printf("Enter head position: ");
    scanf("%d", &head);

    printf("Enter size of disk: ");
    scanf("%d", &size);

    printf("Enter dir (1=Right, 0=Left): ");
    scanf("%d", &dir);

    // Step 1: Sort
    sort(req, n);

    // Step 2: Find split index
    for(int i=0;i<n;i++){
        if(req[i] >= head){
            index = i;
            break;
        }
    }

    printf("\nHead Movement:\n");

    // ================= RIGHT =================
    if(dir == 1){
        // move right
        for(int i=index;i<n;i++){
            printf("%d -> %d\n", head, req[i]);
            total += abs(head - req[i]);
            head = req[i];
        }

        // go to end
        printf("%d -> %d\n", head, size-1);
        total += abs(head - (size-1));
        head = size-1;

        // move left
        for(int i=index-1;i>=0;i--){
            printf("%d -> %d\n", head, req[i]);
            total += abs(head - req[i]);
            head = req[i];
        }
    }

    // ================= LEFT =================
    else{
        // move left
        for(int i=index-1;i>=0;i--){
            printf("%d -> %d\n", head, req[i]);
            total += abs(head - req[i]);
            head = req[i];
        }

        // go to start
        printf("%d -> 0\n", head);
        total += abs(head - 0);
        head = 0;

        // move right
        for(int i=index;i<n;i++){
            printf("%d -> %d\n", head, req[i]);
            total += abs(head - req[i]);
            head = req[i];
        }
    }

    printf("\nTotal Seek Time = %d\n", total);
    printf("Average Seek Time = %.2f\n", (float)total/n);

    return 0;
}
