#include<stdio.h>
#include<stdlib.h>

void sort(int arr[], int n){
    for(int i=0;i<n-1;i++){
        for(int j=0;j<n-i-1;j++){
            if(arr[j] > arr[j+1]){
                int temp = arr[j];
                arr[j] = arr[j+1];
                arr[j+1] = temp;
            }
        }
    }
}

int main(){
    int req[100], n, head, dir, index = 0;
    int total = 0;

    printf("Enter number of requests: ");
    scanf("%d", &n);

    printf("Enter request queue: ");
    for(int i=0;i<n;i++){
        scanf("%d", &req[i]);
    }

    printf("Enter head position: ");
    scanf("%d", &head);

    printf("Enter direction (1=Right, 0=Left): ");
    scanf("%d", &dir);

    // Step 1: Sort
    sort(req, n);

    // Step 2: Find first request >= head
    for(int i=0;i<n;i++){
        if(req[i] >= head){
            index = i;
            break;
        }
    }

    printf("\nHead Movement:\n");

    // ================= RIGHT =================
    if(dir == 1){
        // move right
        for(int i=index;i<n;i++){
            printf("%d -> %d\n", head, req[i]);
            total += abs(head - req[i]);
            head = req[i];
        }

        // reverse (NO going to disk end)
        for(int i=index-1;i>=0;i--){
            printf("%d -> %d\n", head, req[i]);
            total += abs(head - req[i]);
            head = req[i];
        }
    }

    // ================= LEFT =================
    else{
        // move left
        for(int i=index-1;i>=0;i--){
            printf("%d -> %d\n", head, req[i]);
            total += abs(head - req[i]);
            head = req[i];
        }

        // reverse (NO going to 0)
        for(int i=index;i<n;i++){
            printf("%d -> %d\n", head, req[i]);
            total += abs(head - req[i]);
            head = req[i];
        }
    }

    printf("\nTotal Seek Time = %d\n", total);
    printf("Average Seek Time = %.2f\n", (float)total/n);

    return 0;
}
