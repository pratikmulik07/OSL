#include <stdio.h>
#include <stdlib.h>

int main() {
    int req[100], n, head;
    int total = 0;

    printf("Enter number of requests: ");
    scanf("%d", &n);

    printf("Enter request queue: ");
    for(int i = 0; i < n; i++) {
        scanf("%d", &req[i]);
    }

    printf("Enter initial head position: ");
    scanf("%d", &head);

    int visited[100] = {0};

    printf("\nHead Movement:\n");

    for(int i = 0; i < n; i++) {
        int min = 9999, index = -1;

        // Find nearest request
        for(int j = 0; j < n; j++) {
            if(!visited[j]) {
                int distance = abs(head - req[j]);
                if(distance < min) {
                    min = distance;
                    index = j;
                }
            }
        }

        // Move to closest request
        printf("%d -> %d\n", head, req[index]);
        total += abs(head - req[index]);
        head = req[index];

        visited[index] = 1;
    }

    printf("\nTotal Seek Time = %d\n", total);
    printf("Average Seek Time = %.2f\n", (float)total / n);

    return 0;
}
