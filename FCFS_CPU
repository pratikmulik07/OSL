#include<stdio.h>

void sort(int at[], int bt[], int n){
    for(int i=0;i<n-1;i++){
        for(int j=0;j<n-i-1;j++){
            if(at[j]>at[j+1]){
                int temp =at[j];
                at[j]=at[j+1];
                at[j+1]=temp;
                
                temp =bt[j];
                bt[j]=bt[j+1];
                bt[j+1]=temp;
            }
            
        }
    }
}

int main(){
    int n;
    int at[100],bt[100],ct[100],tat[100],wt[100];
    int total_tat=0,total_wt=0;
    
    printf("Enter number of processes:");
    scanf("%d",&n);
    
    
    for(int i=0;i<n;i++){
        printf("Enter at and bt for p%d:",i+1);
        scanf("%d %d",&at[i],&bt[i]);
    }
    
    sort(at,bt,n);
    
    ct[0]=at[0]+bt[0];
    for(int i=1;i<n;i++){
        if(ct[i-1]<=at[i]){
            ct[i]=at[i]+bt[i];
        }else{
            ct[i]=ct[i-1]+bt[i];
        }
    }
    
    for(int i=0;i<n;i++){
        tat[i]=ct[i]-at[i];
        wt[i]=tat[i]-bt[i];
        
        total_tat+=tat[i];
        total_wt+=wt[i];
        
    }
    
    printf("\np\tat\tbt\tct\ttat\twt\n");
    for(int i=0;i<n;i++){
        printf("p%d\t%d\t%d\t%d\t%d\t%d\n",i+1,at[i],bt[i],ct[i],tat[i],wt[i]);
    }
    float avg_tat=(float)total_tat/n;
    float avg_wt=(float)total_wt/n;
    printf("Average Turnaround Time is=%.2f\n",avg_tat);
    printf("Average Waiting Time is=%.2f",avg_wt);
    
    return 0;

}
