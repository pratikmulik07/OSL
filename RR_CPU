#include <stdio.h>

int main(){
    int n,i,tq,time=0,remain;
    int at[10],bt[10],rt[10],ct[10],tat[10],wt[10];
    float avg_tat=0,avg_wt=0;

    printf("--- Round Robin Scheduling ---\n");

    scanf("%d",&n);

    for(i=0;i<n;i++){
        scanf("%d%d",&at[i],&bt[i]);
        rt[i]=bt[i];
    }

    scanf("%d",&tq);

    remain=n;

    while(remain){
        for(i=0;i<n;i++){
            if(rt[i]>0 && at[i]<=time){
                if(rt[i]<=tq){
                    time+=rt[i];
                    rt[i]=0;
                    ct[i]=time;
                    remain--;
                } else {
                    time+=tq;
                    rt[i]-=tq;
                }
            }
        }
    }

    for(i=0;i<n;i++){
        tat[i]=ct[i]-at[i];
        wt[i]=tat[i]-bt[i];

        avg_tat+=tat[i];
        avg_wt+=wt[i];
    }

    avg_tat/=n;
    avg_wt/=n;

    printf("\nProcess AT BT CT TAT WT\n");
    for(i=0;i<n;i++)
        printf("P%d\t%d\t%d\t%d\t%d\t%d\n",i+1,at[i],bt[i],ct[i],tat[i],wt[i]);

    printf("\nAverage Turnaround Time = %.2f",avg_tat);
    printf("\nAverage Waiting Time = %.2f",avg_wt);
}
